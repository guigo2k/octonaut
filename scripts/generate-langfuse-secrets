#!/usr/bin/env bash
set -euo pipefail

NAMESPACE="langfuse"
SECRET_NAME="langfuse-generated-secrets"

kubectl get namespace "${NAMESPACE}" >/dev/null 2>&1 || kubectl create namespace "${NAMESPACE}"

if kubectl get secret "${SECRET_NAME}" -n "${NAMESPACE}" >/dev/null 2>&1; then
  echo "Secret ${SECRET_NAME} already exists in ${NAMESPACE}, leaving it alone."
  exit 0
fi

rand_hex() { openssl rand -hex 16; }
rand_uuid() { cat /proc/sys/kernel/random/uuid; }

kubectl create secret generic "${SECRET_NAME}" -n "${NAMESPACE}" \
  --from-literal=salt="$(openssl rand -base64 32)" \
  --from-literal=nextauth-secret="$(openssl rand -base64 32)" \
  --from-literal=postgres-password="$(rand_hex)" \
  --from-literal=clickhouse-password="$(rand_hex)" \
  --from-literal=redis-password="$(rand_hex)" \
  --from-literal=minio-root-user="minio" \
  --from-literal=minio-root-password="$(rand_hex)" \
  --from-literal=init-org-id="$(rand_uuid)" \
  --from-literal=init-org-name="octonaut" \
  --from-literal=init-project-id="$(rand_uuid)" \
  --from-literal=init-project-name="octonaut" \
  --from-literal=init-project-public-key="pk-lf-$(rand_uuid)" \
  --from-literal=init-project-secret-key="sk-lf-$(rand_uuid)" \
  --from-literal=init-user-email="admin@octonaut.local" \
  --from-literal=init-user-name="Octonaut Admin" \
  --from-literal=init-user-password="$(rand_hex)"

echo "Created secret ${SECRET_NAME} in ${NAMESPACE}."
